<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      Add your internal feed here, e.g.:
      <add key="atya-internal" value="https://pkgs.dev.azure.com/<org>/_packaging/<feed>/nuget/v3/index.json" protocolVersion="3" />
    -->

  </packageSources>

  <!--
    packageSourceMapping defends against dependency-confusion attacks: each
    package can only be pulled from the source you whitelist here.
    Uncomment and extend when you add an internal feed.
  -->
  <!--
  <packageSourceMapping>
    <packageSource key="atya-internal">
      <package pattern="Atya.*" />
      <package pattern="Atya.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
  -->

  <config>
    <add key="defaultPushSource" value="nuget.org" />
  </config>

</configuration>
